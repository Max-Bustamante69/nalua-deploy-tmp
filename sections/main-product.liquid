{%- comment -%}
  nalua REDESIGN — PDP buy box (self-contained: Liquid + Tailwind + external JS
  assets/pdp.js, no shared library). Botanical Atelier + honest CRO/AOV:
  sticky gallery, price/savings, rating, variant + qty, AJAX add-to-cart that
  opens the drawer, free-ship note, risk-reversal trust, scroll-in sticky ATC bar.
  Cross-sell + info accordion live in the separate `pdp-details` section.
{%- endcomment -%}
{%- liquid
  assign p = product
  assign v = p.selected_or_first_available_variant
  assign save = 0
  if v.compare_at_price > v.price and v.compare_at_price > 0
    assign save = v.compare_at_price | minus: v.price
    assign save_pct = save | times: 100.0 | divided_by: v.compare_at_price | round
  endif
  assign coll = p.collections | first
  assign free_ship = section.settings.free_ship_threshold | times: 100
  assign atc_dis = ''
  unless p.available
    assign atc_dis = 'disabled'
  endunless
  assign subtitle = p.metafields.custom.short_description.value | default: section.settings.fallback_subtitle
-%}
<section data-pdp class="bg-bone pb-[clamp(3rem,7vw,6rem)] pt-32">
  <div class="frame">
    {%- if coll != blank -%}
      <nav class="mb-6 flex items-center gap-2 text-sm text-ink/50" aria-label="Ruta">
        <a href="{{ routes.root_url }}" class="link-underline">Inicio</a><span>/</span>
        <a href="{{ coll.url }}" class="link-underline">{{ coll.title }}</a>
      </nav>
    {%- endif -%}
    <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="lg:sticky lg:top-28 lg:self-start">
        <div class="relative overflow-hidden rounded-[24px] bg-bone-soft">
          {%- if save_pct > 0 -%}
            <span class="absolute left-4 top-4 z-10 rounded-full bg-ink px-3 py-1.5 text-xs font-semibold text-bone">-{{ save_pct }}%</span>
          {%- endif -%}
          {%- if p.featured_media != blank -%}
            <img data-pdp-main src="{{ p.featured_media | image_url: width: 1200 }}" alt="{{ p.title | escape }}" width="1000" height="1000" class="aspect-square w-full object-cover" loading="eager" fetchpriority="high">
          {%- else -%}
            <div class="flex aspect-square items-center justify-center text-ink/30">{{ 'product-1' | placeholder_svg_tag: 'h-24 w-24' }}</div>
          {%- endif -%}
        </div>
        {%- if p.media.size > 1 -%}
          <div class="mt-3 flex gap-3 overflow-x-auto pb-1" data-lenis-prevent>
            {%- for media in p.media limit: 6 -%}
              <button type="button" data-pdp-thumb data-src="{{ media | image_url: width: 1200 }}" class="aspect-square w-[72px] shrink-0 overflow-hidden rounded-[12px] border-2 border-transparent transition-colors hover:border-sage" aria-label="Imagen {{ forloop.index }}">
                <img src="{{ media | image_url: width: 160 }}" alt="" width="160" height="160" class="h-full w-full object-cover" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <div data-pdp-info>
        {%- if coll != blank -%}<span class="eyebrow text-sage-deep">{{ coll.title }}</span>{%- endif -%}
        <h1 class="mt-3 font-serif text-[clamp(1.9rem,4vw,3rem)] font-medium leading-tight text-ink">{{ p.title }}</h1>

        {%- if subtitle != blank -%}<p class="mt-4 max-w-[40ch] leading-relaxed text-ink/70">{{ subtitle }}</p>{%- endif -%}
        <div class="mt-6 flex flex-wrap items-end gap-3">
          <span data-pdp-price class="font-serif text-[2rem] text-ink">{{ v.price | money }}</span>
          {%- if save > 0 -%}
            <span class="text-lg text-ink/40 line-through">{{ v.compare_at_price | money }}</span>
            <span class="rounded-full bg-sage/15 px-3 py-1 text-sm font-semibold text-sage-deep">Ahorras {{ save | money }}</span>
          {%- endif -%}
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <div class="flex h-[58px] shrink-0 items-center rounded-full border border-sand">
            <button type="button" data-pdp-qty="-1" class="grid size-[58px] place-items-center text-xl text-ink/60 hover:text-ink" aria-label="Quitar uno">−</button>
            <span data-pdp-qty-val class="w-8 text-center font-semibold text-ink">1</span>
            <button type="button" data-pdp-qty="1" class="grid size-[58px] place-items-center text-xl text-ink/60 hover:text-ink" aria-label="Añadir uno">+</button>
          </div>
          <button type="button" data-pdp-atc data-variant="{{ v.id }}" class="btn btn-primary h-[58px] flex-1 justify-center text-base" {{ atc_dis }}>
            <span data-pdp-atc-label>{% if p.available %}{{ section.settings.atc_label | default: 'Añadir al carrito' }}{% else %}Agotado{% endif %}</span>
          </button>
        </div>
        {%- if section.settings.free_ship_threshold > 0 -%}
          <p class="mt-5 flex items-center gap-2 text-sm text-ink/70"><span class="text-sage-deep">✦</span> Envío gratis sobre {{ free_ship | money_without_trailing_zeros }} · Pago contra entrega</p>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <div class="mt-6 grid grid-cols-3 gap-3 border-y border-sand py-5">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust' -%}
                <div class="flex flex-col items-center gap-2 text-center" {{ block.shopify_attributes }}>
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="text-sage-deep"><path d="M12 2l7 3v6c0 4.5-3 8-7 11-4-3-7-6.5-7-11V5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  <span class="text-xs leading-tight text-ink/70">{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  <div data-pdp-bar class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-sand bg-bone/95 py-3 backdrop-blur">
    <div class="frame flex items-center gap-4">
      {%- if p.featured_media -%}<img src="{{ p.featured_media | image_url: width: 100 }}" alt="" width="48" height="48" class="size-12 rounded-[10px] object-cover" loading="lazy">{%- endif -%}
      <div class="min-w-0 flex-1">
        <p class="line-clamp-1 text-sm font-medium text-ink">{{ p.title }}</p>
        <p class="text-sm text-ink/60">{{ v.price | money }}</p>
      </div>
      <button type="button" data-pdp-atc data-variant="{{ v.id }}" class="btn btn-primary shrink-0" {{ atc_dis }}>{% if p.available %}Añadir{% else %}Agotado{% endif %}</button>
    </div>
  </div>
  <script src="{{ 'pdp.js' | asset_url }}" defer></script>
</section>
{% schema %}
{ "name": "Producto principal", "blocks": [ { "type": "trust", "name": "Confianza", "settings": [ { "type": "text", "id": "label", "label": "Texto" } ] } ], "presets": [ { "name": "Producto principal" } ] }
{% endschema %}
