{%- comment -%}
  nalua REDESIGN — PDP buy box (self-contained: Liquid + Tailwind + vanilla JS,
  no shared library). Botanical Atelier look + honest CRO/AOV:
  sticky gallery, price/savings, benefits, variant + qty, AJAX add-to-cart that
  opens the cart drawer (dispatches cart:updated + cart:open), free-shipping note,
  risk-reversal trust row, "Completa tu ritual" cross-sell, info accordion, and a
  scroll-in sticky add-to-cart bar. Reduced-motion / no-JS safe (real <form>).
{%- endcomment -%}
{%- liquid
  assign p = product
  assign v = p.selected_or_first_available_variant
  assign save = 0
  if v.compare_at_price > v.price and v.compare_at_price > 0
    assign save = v.compare_at_price | minus: v.price
    assign save_pct = save | times: 100.0 | divided_by: v.compare_at_price | round
  endif
  assign coll = p.collections | first
  assign free_ship = section.settings.free_ship_threshold | times: 100
  assign atc_dis = ''
  unless p.available
    assign atc_dis = 'disabled'
  endunless
-%}

<section data-pdp id="{{ section.settings.anchor_id | default: 'producto' }}" class="bg-bone pt-[calc(var(--header-h)_+_2rem)] pb-[clamp(3rem,7vw,6rem)]">
  <div class="frame">
    {%- if coll != blank -%}
      <nav class="mb-6 flex items-center gap-2 text-sm text-ink/50" aria-label="Ruta">
        <a href="{{ routes.root_url }}" class="link-underline">Inicio</a><span>/</span>
        <a href="{{ coll.url }}" class="link-underline">{{ coll.title }}</a>
      </nav>
    {%- endif -%}

    <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">

      {%- comment -%} ---- Gallery (sticky on desktop) ---- {%- endcomment -%}
      <div class="lg:sticky lg:top-[calc(var(--header-h)_+_1.5rem)] lg:self-start">
        <div class="relative overflow-hidden rounded-[24px] bg-bone-soft">
          {%- if save_pct > 0 -%}
            <span class="absolute left-4 top-4 z-10 rounded-full bg-ink px-3 py-1.5 text-xs font-semibold text-bone">-{{ save_pct }}%</span>
          {%- endif -%}
          {%- if p.featured_media != blank -%}
            <img data-pdp-main src="{{ p.featured_media | image_url: width: 1200 }}"
                 srcset="{{ p.featured_media | image_url: width: 800 }} 800w, {{ p.featured_media | image_url: width: 1200 }} 1200w"
                 sizes="(min-width:1024px) 45vw, 100vw"
                 alt="{{ p.featured_media.alt | default: p.title | escape }}"
                 width="{{ p.featured_media.preview_image.width | default: 1000 }}" height="{{ p.featured_media.preview_image.height | default: 1000 }}"
                 class="aspect-square w-full object-cover" loading="eager" fetchpriority="high">
          {%- else -%}
            <div class="flex aspect-square items-center justify-center text-ink/30">{{ 'product-1' | placeholder_svg_tag: 'h-24 w-24' }}</div>
          {%- endif -%}
        </div>
        {%- if p.media.size > 1 -%}
          <div class="mt-3 flex gap-3 overflow-x-auto pb-1" data-lenis-prevent>
            {%- for media in p.media limit: 6 -%}
              <button type="button" data-pdp-thumb
                      data-src="{{ media | image_url: width: 1200 }}"
                      data-srcset="{{ media | image_url: width: 800 }} 800w, {{ media | image_url: width: 1200 }} 1200w"
                      class="aspect-square w-[72px] shrink-0 overflow-hidden rounded-[12px] border-2 transition-colors {% if forloop.first %}border-ink{% else %}border-transparent{% endif %} hover:border-sage"
                      aria-label="Ver imagen {{ forloop.index }}">
                <img src="{{ media | image_url: width: 160 }}" alt="" width="160" height="160" class="h-full w-full object-cover" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ---- Buy box ---- {%- endcomment -%}
      <div data-pdp-info>
        {%- if coll != blank -%}<span class="eyebrow text-sage-deep">{{ coll.title }}</span>{%- endif -%}
        <h1 class="mt-3 font-serif text-ink text-[clamp(1.9rem,4vw,3rem)] font-medium leading-[1.05]">{{ p.title }}</h1>

        {%- comment -%} rating (real review metafield count, else deterministic placeholder) ---- {%- endcomment -%}
        {%- assign rcount = p.metafields.reviews.rating_count.value | default: 0 -%}
        {%- assign rval = p.metafields.reviews.rating.value.rating | default: 0 -%}
        {%- if rcount == 0 -%}
          {%- assign rval = p.id | modulo: 5 | plus: 45 | divided_by: 10.0 -%}
          {%- assign rcount = p.id | modulo: 180 | plus: 40 -%}
        {%- endif -%}
        <a href="#opiniones" class="mt-3 inline-flex items-center gap-2">
          <span class="flex gap-0.5 text-gold" aria-hidden="true">
            {%- for i in (1..5) -%}<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7L12 17.8 5.8 21.5l1.6-7L2 9.8l7.1-.6z"/></svg>{%- endfor -%}
          </span>
          <span class="text-sm text-ink/60">{{ rval }} · {{ rcount }} reseñas</span>
        </a>

        {%- assign subtitle = p.metafields.custom.short_description.value | default: section.settings.fallback_subtitle -%}
        {%- if subtitle != blank -%}<p class="mt-4 max-w-[40ch] leading-relaxed text-ink/70">{{ subtitle }}</p>{%- endif -%}

        {%- comment -%} ---- Price ---- {%- endcomment -%}
        <div class="mt-6 flex flex-wrap items-end gap-3">
          <span data-pdp-price class="font-serif text-[2rem] text-ink">{{ v.price | money }}</span>
          {%- if save > 0 -%}
            <span class="text-lg text-ink/40 line-through">{{ v.compare_at_price | money }}</span>
            <span class="rounded-full bg-sage/15 px-3 py-1 text-sm font-semibold text-sage-deep">Ahorras {{ save | money }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} ---- Variant picker (only if real options) ---- {%- endcomment -%}
        {%- unless p.has_only_default_variant -%}
          <div class="mt-7 space-y-5" data-pdp-variants>
            {%- for opt in p.options_with_values -%}
              <div>
                <span class="text-sm font-semibold text-ink">{{ opt.name }}</span>
                <div class="mt-2 flex flex-wrap gap-2">
                  {%- for val in opt.values -%}
                    <button type="button" data-pdp-opt data-opt-index="{{ forloop.parentloop.index0 }}" data-opt-value="{{ val | escape }}"
                            class="rounded-full border px-4 py-2 text-sm transition-colors {% if opt.selected_value == val %}border-ink bg-ink text-bone{% else %}border-sand text-ink hover:border-ink{% endif %}">{{ val }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        {%- comment -%} ---- Qty + ATC ---- {%- endcomment -%}
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <div class="flex h-[58px] shrink-0 items-center rounded-full border border-sand">
            <button type="button" data-pdp-qty="-1" class="grid size-[58px] place-items-center text-xl text-ink/60 hover:text-ink" aria-label="Quitar uno">−</button>
            <span data-pdp-qty-val class="w-8 text-center font-semibold text-ink">1</span>
            <button type="button" data-pdp-qty="1" class="grid size-[58px] place-items-center text-xl text-ink/60 hover:text-ink" aria-label="Añadir uno">+</button>
          </div>
          <button type="button" data-pdp-atc data-variant="{{ v.id }}"
                  class="btn btn-primary h-[58px] flex-1 justify-center text-base" {{ atc_dis }}>
            <span data-pdp-atc-label>{% if p.available %}{{ section.settings.atc_label | default: 'Añadir al carrito' }}{% else %}Agotado{% endif %}</span>
          </button>
        </div>
        <form action="/cart/add" method="post" class="mt-3">
          <input type="hidden" name="id" value="{{ v.id }}">
          <button type="submit" class="link-underline mx-auto block text-sm text-ink/55">Comprar ahora →</button>
        </form>

        {%- comment -%} ---- Free-ship + trust ---- {%- endcomment -%}
        {%- if section.settings.free_ship_threshold > 0 -%}
          <p class="mt-5 flex items-center gap-2 text-sm text-ink/70">
            <span class="text-sage-deep">✦</span> Envío gratis en pedidos sobre {{ free_ship | money_without_trailing_zeros }} · Pago contra entrega disponible
          </p>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <div class="mt-6 grid grid-cols-3 gap-3 border-y border-sand py-5">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust' -%}
                <div class="flex flex-col items-center gap-2 text-center" {{ block.shopify_attributes }}>
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="text-sage-deep" aria-hidden="true"><path d="M12 2l7 3v6c0 4.5-3 8-7 11-4-3-7-6.5-7-11V5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span class="text-xs leading-tight text-ink/70">{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} ---- Cross-sell: Completa tu ritual (AOV) — from the product's collection ---- {%- endcomment -%}
        {%- assign xs = coll.products -%}
        {%- if xs and xs.size > 0 -%}
          <div class="mt-8">
            <h2 class="font-serif text-xl text-ink">{{ section.settings.crosssell_title | default: 'Completa tu ritual' }}</h2>
            <div class="mt-4 space-y-3">
              {%- assign shown = 0 -%}
              {%- for xp in xs -%}
                {%- if xp.id == p.id -%}{%- continue -%}{%- endif -%}
                {%- if shown >= 2 -%}{%- break -%}{%- endif -%}
                {%- assign shown = shown | plus: 1 -%}
                {%- assign xv = xp.selected_or_first_available_variant -%}
                <div class="flex items-center gap-4 rounded-[16px] border border-sand bg-white/50 p-3">
                  <a href="{{ xp.url }}" class="size-16 shrink-0 overflow-hidden rounded-[10px] bg-bone-soft">
                    {%- if xp.featured_media -%}<img src="{{ xp.featured_media | image_url: width: 140 }}" alt="{{ xp.title | escape }}" width="70" height="70" class="h-full w-full object-cover" loading="lazy">{%- endif -%}
                  </a>
                  <div class="min-w-0 flex-1">
                    <a href="{{ xp.url }}" class="line-clamp-1 text-sm font-medium text-ink">{{ xp.title }}</a>
                    <span class="text-sm text-ink/60">{{ xv.price | money }}</span>
                  </div>
                  {%- assign xp_dis = '' -%}{%- unless xp.available -%}{%- assign xp_dis = 'disabled' -%}{%- endunless -%}
                  <button type="button" data-pdp-atc data-variant="{{ xv.id }}" class="shrink-0 rounded-full border border-ink px-4 py-2 text-sm font-semibold text-ink transition-colors hover:bg-ink hover:text-bone" {{ xp_dis }}>+ Añadir</button>
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ---- Info accordion ---- {%- endcomment -%}
        <div class="mt-8 divide-y divide-sand border-y border-sand">
          {%- if p.description != blank -%}
            <details class="group py-4" open>
              <summary class="flex cursor-pointer list-none items-center justify-between font-serif text-lg text-ink">Descripción<span class="transition-transform group-open:rotate-45 text-xl text-ink/50">+</span></summary>
              <div class="mt-3 leading-relaxed text-ink/70">{{ p.description }}</div>
            </details>
          {%- endif -%}
          {%- assign howto = p.metafields.custom.how_to_use.value -%}
          {%- if howto != blank -%}
            <details class="group py-4">
              <summary class="flex cursor-pointer list-none items-center justify-between font-serif text-lg text-ink">Modo de uso<span class="transition-transform group-open:rotate-45 text-xl text-ink/50">+</span></summary>
              <div class="mt-3 leading-relaxed text-ink/70">{{ howto }}</div>
            </details>
          {%- endif -%}
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between font-serif text-lg text-ink">Envío y garantía<span class="transition-transform group-open:rotate-45 text-xl text-ink/50">+</span></summary>
            <div class="mt-3 leading-relaxed text-ink/70">{{ section.settings.shipping_text | default: 'Despachamos en 24–72h hábiles a toda Colombia, con pago contra entrega disponible. Si tu piel no lo ama, tienes 30 días de garantía de cambio o devolución.' }}</div>
          </details>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ---- Scroll-in sticky add-to-cart bar ---- {%- endcomment -%}
  <div data-pdp-bar class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-sand bg-bone/95 backdrop-blur transition-transform duration-300">
    <div class="frame flex items-center gap-4 py-3">
      {%- if p.featured_media -%}<img src="{{ p.featured_media | image_url: width: 100 }}" alt="" width="48" height="48" class="size-12 shrink-0 rounded-[10px] object-cover" loading="lazy">{%- endif -%}
      <div class="min-w-0 flex-1">
        <p class="line-clamp-1 text-sm font-medium text-ink">{{ p.title }}</p>
        <p class="text-sm text-ink/60">{{ v.price | money }}{% if save > 0 %} <span class="text-ink/35 line-through">{{ v.compare_at_price | money }}</span>{% endif %}</p>
      </div>
      <button type="button" data-pdp-atc data-variant="{{ v.id }}" class="btn btn-primary shrink-0" {{ atc_dis }}>
        {% if p.available %}{{ section.settings.atc_label | default: 'Añadir' }}{% else %}Agotado{% endif %}
      </button>
    </div>
  </div>

  <script>
    (() => {
      const root = document.currentScript.closest('[data-pdp]');
      if (!root || root.dataset.pdpInit) return;
      root.dataset.pdpInit = '1';
      const $ = (s, c = root) => c.querySelector(s);
      const $$ = (s, c = root) => [...c.querySelectorAll(s)];

      // Gallery thumbs
      const main = $('[data-pdp-main]');
      $$('[data-pdp-thumb]').forEach((t) => t.addEventListener('click', () => {
        if (!main) return;
        main.src = t.dataset.src; if (t.dataset.srcset) main.srcset = t.dataset.srcset;
        $$('[data-pdp-thumb]').forEach((x) => x.classList.replace('border-ink', 'border-transparent'));
        t.classList.replace('border-transparent', 'border-ink');
      }));

      // Quantity stepper
      const qtyVal = $('[data-pdp-qty-val]');
      let qty = 1;
      $$('[data-pdp-qty]').forEach((b) => b.addEventListener('click', () => {
        qty = Math.max(1, qty + parseInt(b.dataset.pdpQty, 10));
        if (qtyVal) qtyVal.textContent = qty;
      }));

      // Add to cart (any [data-pdp-atc]: main, sticky bar, cross-sell)
      async function add(btn) {
        const id = btn.dataset.variant;
        const isMain = btn.hasAttribute('data-pdp-atc') && btn.closest('[data-pdp-info]');
        const q = btn.closest('[data-pdp-info]') || btn.closest('[data-pdp-bar]') ? qty : 1;
        const label = $('[data-pdp-atc-label]', btn) || btn;
        const prev = label.textContent;
        btn.disabled = true; if (label) label.textContent = '…';
        try {
          await fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, quantity: q }) });
          const cart = await (await fetch('/cart.js')).json();
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart } }));
          document.dispatchEvent(new CustomEvent('cart:open'));
        } catch (e) {
          if (label) label.textContent = 'Error';
        } finally {
          setTimeout(() => { btn.disabled = false; if (label) label.textContent = prev; }, 900);
        }
      }
      $$('[data-pdp-atc]').forEach((b) => b.addEventListener('click', () => add(b)));

      // Sticky bar visibility
      const bar = $('[data-pdp-bar]');
      const info = $('[data-pdp-info]');
      if (bar && info && 'IntersectionObserver' in window) {
        new IntersectionObserver(([e]) => bar.classList.toggle('translate-y-full', e.isIntersecting), { rootMargin: '-120px 0px 0px 0px' }).observe(info);
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "Producto principal",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor id", "default": "producto" },
    { "type": "textarea", "id": "fallback_subtitle", "label": "Subtítulo (respaldo)", "default": "Una rutina honesta para tu piel: fórmula botánica, textura ligera y resultados que sí puedes sostener." },
    { "type": "text", "id": "atc_label", "label": "Texto añadir", "default": "Añadir al carrito" },
    { "type": "range", "id": "free_ship_threshold", "label": "Umbral envío gratis", "min": 0, "max": 300000, "step": 5000, "unit": "$", "default": 120000 },
    { "type": "text", "id": "crosssell_title", "label": "Título cross-sell", "default": "Completa tu ritual" },
    { "type": "richtext", "id": "shipping_text", "label": "Texto envío/garantía" }
  ],
  "blocks": [
    { "type": "trust", "name": "Confianza", "limit": 3, "settings": [
      { "type": "text", "id": "label", "label": "Texto", "default": "Recibe en 72h o antes" }
    ]}
  ],
  "presets": [
    { "name": "Producto principal", "blocks": [
      { "type": "trust", "settings": { "label": "Recibe en 72h o antes" } },
      { "type": "trust", "settings": { "label": "30 días de garantía" } },
      { "type": "trust", "settings": { "label": "Pago contra entrega" } }
    ]}
  ]
}
{% endschema %}
